{
  "expo": {
    "name": "Eco Escuela",
    "slug": "eco-escuela",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "eco-escuela",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1B5E38"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ecoescuela.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Necesitamos acceso a la cámara para tomar fotos de evidencia de tus obras ecológicas.",
        "NSPhotoLibraryUsageDescription": "Necesitamos acceso a tu galería para adjuntar fotos de evidencia.",
        "NSPhotoLibraryAddUsageDescription": "Necesitamos guardar fotos de tus obras ecológicas."
      }
    },
    "android": {
      "package": "com.ecoescuela.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#1B5E38"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "Necesitamos acceso a tu galería para adjuntar fotos de tus obras.",
          "cameraPermission": "Necesitamos acceso a la cámara para tomar fotos de evidencia."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#1B5E38",
          "sounds": []
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "eco-escuela"
      }
    },
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
